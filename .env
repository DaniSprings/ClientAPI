PORT=4000
NODE_ENV=development

# Comma-separated allowlist used by CORS.
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5173,http://127.0.0.1:5173

# SQL Server connection settings.
# This machine's SQL Server instance is listening on 127.0.0.1:52741.
DB_SERVER=127.0.0.1
DB_PORT=52741
DB_NAME=RevReviewData
DB_USE_WINDOWS_AUTH=true
# Windows integrated authentication is the default local setup.
# Only set DB_USER and DB_PASSWORD if you explicitly disable DB_USE_WINDOWS_AUTH.
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Security settings.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2h
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Development-only helper for the popup-based social login buttons in the UI.
ALLOW_DEV_SOCIAL_LOGIN=false

# Supabase settings for server-side API reads.
SUPABASE_URL=https://qceqjmtgacdwqxrdbmwj.supabase.co
# Replace with service_role key when available; anon key works only for publicly readable tables.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFjZXFqbXRnYWNkd3F4cmRibXdqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0MjUyMDcsImV4cCI6MjA5MDAwMTIwN30.I825NaDTEvDuUUJ4dh_ztOt2iHCTtItxTduhgmFwFYk
